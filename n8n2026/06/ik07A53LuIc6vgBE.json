      "parameters": {
        "jsCode": "const eventos = $input.all().map(i => i.json);\nconst uid = $('Extrair dados do ICS').first().json.uid;\n\nconst evento = eventos.find(e =>\n  JSON.stringify(e).includes(uid)\n);\n\nif (!evento) {\n  return [\n    {\n      json: {\n        ...$('Extrair dados do ICS').first().json,\n        eventoEncontrado: false,\n        mensagem: 'Cancelamento recebido, mas nenhum evento com esse UID foi encontrado na agenda.'\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      ...$('Extrair dados do ICS').first().json,\n      eventoEncontrado: true,\n      eventId: evento.id\n    }\n  }\n];"
      },
