    {
      "parameters": {
        "jsCode": "const email = $('Separar emails').item.json;\n\nconst anexos = $json.data?.attachments || [];\nconst inline = $json.data?.inline || [];\nconst todos = [...anexos, ...inline];\n\nconst ics = todos.find(a =>\n  String(a.attachmentName || a.fileName || '')\n    .toLowerCase()\n    .endsWith('.ics')\n);\n\nif (!ics) {\n  return [\n    {\n      json: {\n        ...email,\n        hasICS: false,\n        motivo: 'Nenhum .ics encontrado via Zoho API neste e-mail.'\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      ...email,\n      hasICS: true,\n      attachmentId: ics.attachmentId,\n      attachmentName: ics.attachmentName || ics.fileName\n    }\n  }\n];"
      },
      "id": "fbfcc81d-cbcc-4120-8b28-f122ac4665ff",
      "name": "Selecionar ICS",
