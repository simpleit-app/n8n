        "url": "=https://mail.zoho.com/api/accounts/{{$json.accountId}}/folders/{{$json.folderId}}/messages/{{$json.messageId}}/attachmentinfo",
        "authentication": "genericCredentialType",
        "genericAuthType": "oAuth2Api",
